# Database
DATABASE_URL=postgresql://postgres:jaishreeram@db.xdqouhlsfdksbqbbdqwq.supabase.co:5432/postgres
# For local SQLite dev: sqlite:///./traffic.db

# JWT
SECRET_KEY=mysecretkey
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# AWS S3 (for evidence storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=traffic-evidence-bucket
# Set to "local" to use local storage instead of S3
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./evidence_files

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@trafficviolations.gov

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE=+1234567890

# App
APP_NAME=Traffic Violation Detection System
APP_ENV=development
